# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# Required: Password for the public gallery page (index.html)
export BIRTHDAY_PAGE_PASSWORD=your-public-password-here

# Optional: Separate password for the admin upload page (upload.html)
# If not set, falls back to BIRTHDAY_PAGE_PASSWORD
export ADMIN_PAGE_PASSWORD=your-admin-password-here

# Optional: Enable HTTPS (requires cert.pem and key.pem)
# export ENABLE_HTTPS=true

# Optional: Custom SSL certificate paths
# export SSL_CERTFILE=cert.pem
# export SSL_KEYFILE=key.pem
