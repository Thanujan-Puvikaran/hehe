# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# Required: Password for the public gallery page (index.html)
export BIRTHDAY_PAGE_PASSWORD=your-public-password-here

# Optional: Separate password for the admin upload page (upload.html)
# If not set, falls back to BIRTHDAY_PAGE_PASSWORD
export ADMIN_PAGE_PASSWORD=your-admin-password-here

# Required: Firebase web app config (served by server at /firebase-config.json)
export FIREBASE_API_KEY=your-firebase-web-api-key
export FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
export FIREBASE_DATABASE_URL=https://your-project-default-rtdb.region.firebasedatabase.app
export FIREBASE_PROJECT_ID=your-project-id
export FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
export FIREBASE_MESSAGING_SENDER_ID=1234567890
export FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890

# Optional: Enable HTTPS (requires cert.pem and key.pem)
# export ENABLE_HTTPS=true

# Optional: Custom SSL certificate paths
# export SSL_CERTFILE=cert.pem
# export SSL_KEYFILE=key.pem
